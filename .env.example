# ---- General ----

# Your domain name
BASE_DOMAIN=example.com

# Email for Let's Encrypt certificate registration
ACME_EMAIL=you@example.com

# ---- Droplet (Pangolin) ----

# Pangolin server secret (min 32 chars, used for encryption)
# Generate with: openssl rand -hex 32
SERVER_SECRET=changeme

# ---- phd-server (Newt) ----

# Newt credentials (from Pangolin dashboard)
NEWT_ID=changeme
NEWT_SECRET=changeme

# ---- phd-server (Jellyfin) ---- 

# Path to Jellyfin media library on the host
JELLYFIN_MEDIA_PATH=/path/to/media

# ---- phd-server (Immich) ----

# Postgres password for Immich (A-Za-z0-9 only)
# Generate with: openssl rand -hex 16
IMMICH_DB_PASSWORD=changeme
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich

# Path to Immich photo library on the host
IMMICH_LIBRARY_PATH=/path/to/immich/library

# Path to Immich Postgres data on the host
IMMICH_DB_PATH=/path/to/immich/postgres

# ---- phd-server (Websidian) ----

# Path to your Obsidian vault on the host
VAULT_PATH=/path/to/obsidian/vault

# ---- phd-server (Open WebUI + Ollama) ----

# Path to Ollama model data on the host
OLLAMA_DATA_PATH=/path/to/ollama/data

# DGX Spark mDNS hostname (leave empty if not using a Spark)
# The Makefile resolves this to an IP at startup so containers can reach it
SPARK_HOSTNAME=

# Ollama URLs for Open WebUI (semicolon-separated)
# If SPARK_HOSTNAME is set, the Spark is appended automatically on startup
OPEN_WEBUI_OLLAMA_URLS=http://ollama:11434
